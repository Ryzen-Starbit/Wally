{
  "name": "wallpaper-app",
  "version": "1.0.0",
  "scripts": {
    "predev": "node -e \"require('kill-port')(3001).then(()=>console.log('Port 3001 cleared')).catch(()=>console.log('Port 3001 was free'))\"",
    "server": "node server.js",
    "client": "cd client && npm run dev",
    "dev": "concurrently --kill-others-on-fail \"npm run server\" \"npm run client\""
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "firebase": "^12.15.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.0",
    "kill-port": "^2.0.1"
  }
}
